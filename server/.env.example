# ============================================================
# Variáveis de ambiente do backend de gestão
# Copie para .env (local) ou configure no painel da Railway.
# NUNCA versione o .env real com valores preenchidos.
# ============================================================

# String de conexão do Postgres.
# - Local:   postgres://usuario:senha@localhost:5432/gestao
# - Railway: injetada automaticamente ao adicionar o plugin Postgres.
DATABASE_URL=

# Senha do nível MESTRE (pode editar e salvar).
MASTER_PASSWORD=

# Senha do nível VISUALIZADOR (apenas leitura).
VIEWER_PASSWORD=

# Segredo para assinar o cookie de sessão (use uma string longa e aleatória).
# Gere uma: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# (opcional) Porta local. A Railway injeta PORT automaticamente.
# PORT=3000

# (opcional) Defina como "production" na Railway para cookies Secure + SSL no banco.
# NODE_ENV=production
